# 🦜 VietFi Advisor - AI Configuration 🦜
# ────────────────────────────────────────

# AI Provider Configuration
# Supported values: 'trollllm' (default), 'gemini'
AI_PROVIDER=trollllm

# TrollLLM API Key (OpenAI Compatible)
# Get from: https://chat.trollllm.xyz
TROLL_LLM_API_KEY=sk-trollllm-xxx...

# Google Gemini API Key (Fallback or Direct)
# Get from: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# ────────────────────────────────────────
# Core App Infrastructure
# ────────────────────────────────────────

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Automation & Security
CRON_SECRET=your_cron_secret_here
# Set to 1 to enable AI-powered news vetting (costs more tokens)
ENABLE_NEWS_AI_REVIEW=1

# ────────────────────────────────────────
# End of .env.example
