# 🦜 VietFi Advisor - AI Configuration 🦜
# ────────────────────────────────────────

# AI provider to use for chat requests.
# Supported values: gemini, openai, llm, api, zen
AI_PROVIDER=gemini

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here
# Optional OpenAI proxy URL
OPENAI_BASE_URL=

# Google Gemini API Key
# Get from: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Optional Gemini proxy URL
GEMINI_BASE_URL=

# Disable AI summary generation (Set to 1 to disable)
DISABLE_GEMINI_SUMMARY=0

# ────────────────────────────────────────
# Core App Infrastructure
# ────────────────────────────────────────

# Supabase Configuration
APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Automation & Security
CRON_SECRET=your_cron_secret_here
# Set to 1 to enable AI-powered news vetting (costs more tokens)
ENABLE_NEWS_AI_REVIEW=1

# ────────────────────────────────────────
# End of .env.example
