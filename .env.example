# 🦜 VietFi Advisor - AI Configuration 🦜
# ────────────────────────────────────────

# Google Gemini API Key (Optional)
# Get from: https://aistudio.google.com
# Preferred name used by the Google SDK:
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here
# Backward-compatible alias used by older code:
GEMINI_API_KEY=your_gemini_api_key_here

# ────────────────────────────────────────
# Core App Infrastructure
# ────────────────────────────────────────

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Automation & Security
CRON_SECRET=your_cron_secret_here
# Set to 1 to enable AI-powered news vetting (costs more tokens)
ENABLE_NEWS_AI_REVIEW=1

# ────────────────────────────────────────
# Monetization
# ────────────────────────────────────────
# Comma-separated promo codes that grant VIP access (read from env — never hardcode)
NEXT_PUBLIC_VIETFI_PROMO_CODES="HUNGPIXI,TESTVIP"

# Enable mock premium auth (Phase 2 only — MUST be false in production)
MOCK_AUTH_ENABLED=false

# ────────────────────────────────────────
# End of .env.example
